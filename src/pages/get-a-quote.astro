---
import BaseLayout from '@/layouts/BaseLayout.astro';
import LeadGenForm from '@/components/LeadGenForm.astro';

const ROOFING_SERVICES = [
  'Roof Replacement',
  'Roof Repair',
  'Gutter Installation / Repair',
  'Roof Inspection',
  'New Construction Roofing',
  'Skylight Installation',
  'Emergency Roof Repair',
  'Other Roofing Service',
];
---

<BaseLayout
  title="Get a Free Roofing Estimate | ShingleScience"
  description="Request a free estimate from a certified local roofer. No obligation — we'll match you with a qualified pro in your area."
>
  <section class="py-16 md:py-24 bg-surface">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-12 items-start">
        <div class="pt-4">
          <span class="inline-block bg-primary/10 text-primary text-sm font-semibold px-3 py-1 rounded-full mb-4">Free & No Obligation</span>
          <h1 class="text-4xl md:text-5xl font-bold font-heading text-text leading-tight mb-6">
            Get a Free Roofing Estimate
          </h1>
          <p class="text-lg text-text-muted mb-8 leading-relaxed">
            Tell us about your roofing project and we'll connect you with a certified local roofer within 1 business day. No hidden fees, no pressure.
          </p>
          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <span class="text-primary font-bold text-lg mt-0.5">✓</span>
              <div>
                <p class="font-semibold text-text">Certified & Insured Roofers</p>
                <p class="text-text-muted text-sm">Every roofer in our network is licensed, insured, and background-checked.</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-primary font-bold text-lg mt-0.5">✓</span>
              <div>
                <p class="font-semibold text-text">Fast Response</p>
                <p class="text-text-muted text-sm">Receive a callback or email within 1 business day of submitting your request.</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-primary font-bold text-lg mt-0.5">✓</span>
              <div>
                <p class="font-semibold text-text">No Obligation</p>
                <p class="text-text-muted text-sm">Getting an estimate is free. You decide if and when to move forward.</p>
              </div>
            </li>
          </ul>
        </div>
        <div>
          <LeadGenForm
            siteId="shinglescience"
            serviceTypes={ROOFING_SERVICES}
            heading="Request Your Free Estimate"
            subheading="Fill out the form and a certified roofer will be in touch shortly."
            variant="page"
          />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
